generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DIREKTUR
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(CUSTOMER)
  addresses Address[]
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  label      String
  recipient  String
  phone      String
  fullAddress String
  city       String
  province   String
  postalCode String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  imageUrl String?
  products Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  price       Int
  compareAtPrice Int?
  sku         String      @unique
  stock       Int         @default(0)
  frameShape  String?
  frameMaterial String?
  images      ProductImage[]
  category    Category    @relation(fields: [categoryId], references: [id])
  categoryId  String
  isActive    Boolean     @default(true)
  isFeatured  Boolean     @default(false)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Singleton row (id is always "main") holding editable homepage/footer copy
// so admins can change hero text, value props, footer info, etc. without code changes.
model SiteContent {
  id        String   @id @default("main")
  data      Json
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  position  Int     @default(0)
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  items         OrderItem[]
  subtotal      Int
  shippingCost  Int         @default(0)
  total         Int
  status        OrderStatus @default(PENDING)
  recipientName String
  phone         String
  shippingAddress String
  city          String
  province      String
  postalCode    String
  midtransOrderId String?   @unique
  midtransToken   String?
  paymentType     String?
  paidAt          DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  name      String
  price     Int
  quantity  Int
}

model License {
  id         Int      @id @default(autoincrement())
  tokenCode  String   @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  expiredAt  DateTime
}